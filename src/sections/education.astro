---
import i18n from "i18next";

import { AcademicCapIcon } from "@heroicons/react/24/outline";

import PinnedSection from "../components/PinnedSection.astro";

const education = i18n.t("education-items", { returnObjects: true });
const languages = i18n.t("language-items", { returnObjects: true });
---

<PinnedSection id="education" title={i18n.t("education-label")} class="bg-alice-blue-50">
    <AcademicCapIcon
        slot="title-icon"
        className="h-6 w-6 md:h-10 md:w-10 text-alice-blue-400"
    />

    <div class="grid gap-8">
        <section>
            <h3 class="mb-4 font-mono text-xl font-medium tracking-tight text-alice-blue-400">
                {i18n.t("education-label")}
            </h3>
            <div class="grid gap-4 sm:grid-cols-2">
                {
                    education.map((item) => (
                        <article class="gsap-reveal-card rounded-2xl border border-alice-blue-400/20 bg-white/95 p-6 shadow-sm transition-shadow duration-200 hover:shadow-md">
                            <div class="flex h-full flex-col">
                                <p class="text-sm font-medium text-custom-neutral/80">{item.period}</p>
                                <h4 class="mt-3 font-mono text-xl font-medium tracking-tight text-alice-blue-400">
                                    {item.title}
                                </h4>
                                <p class="mt-3 text-sm text-custom-neutral md:text-base">{item.institution}</p>
                                {item.location && <p class="mt-1 text-sm text-custom-neutral md:text-base">{item.location}</p>}
                            </div>
                        </article>
                    ))
                }
            </div>
        </section>

        <section id="languages">
            <h3 class="mb-4 font-mono text-xl font-medium tracking-tight text-alice-blue-400">
                {i18n.t("languages-label")}
            </h3>
            <article class="gsap-reveal-card rounded-2xl border border-alice-blue-400/20 bg-white/95 p-6 shadow-sm transition-shadow duration-200 hover:shadow-md">
                <ul class="grid gap-3 sm:grid-cols-2">
                    {
                        languages.map((language) => (
                            <li class="flex items-center gap-2 text-sm text-custom-neutral md:text-base">
                                <span class="size-1.5 shrink-0 rounded-full bg-alice-blue-950" aria-hidden="true"></span>
                                <span>{language}</span>
                            </li>
                        ))
                    }
                </ul>
            </article>
        </section>
    </div>
</PinnedSection>
