---
import i18n from "i18next";

import { BuildingOffice2Icon } from "@heroicons/react/24/outline";

import TimelineCard from "../components/TimelineCard.astro";
import PinnedSection from "../components/PinnedSection.astro";

const professionalExperiences = i18n.t("experiences", {
    ns: "professional-experiences",
    returnObjects: true,
});
---

<PinnedSection
    id="professional-experience"
    title={i18n.t("professional-experience-label")}
    class="bg-alice-blue-50"
>
    <BuildingOffice2Icon
        slot="title-icon"
        className="h-6 w-6 md:h-10 md:w-10 text-alice-blue-400"
    />

    <div class="flex flex-col gap-8">
        {
            professionalExperiences.map(item => (
                <TimelineCard 
                    title={`${item.title} ${item.company ? ` at ${item.company}` : ''}`}
                    subtitle={item.period}
                >
                    <ul class="list-disc space-y-2 pl-5">
                        {item.highlights.map((highlight) => (
                            <li>{highlight}</li>
                        ))}
                    </ul>
                </TimelineCard>
            ))
        }
    </div>
</PinnedSection>
