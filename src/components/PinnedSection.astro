---
interface Props {
    id: string;
    title: string;
    side?: "left" | "right";
    class?: string;
    color?: string;
    colorOut?: string;
}

const { id, title, side = "left", class: className, color, colorOut } = Astro.props;
const isTitleOnLeft = side === "left";
---

<section
    id={id}
    data-pinned-section
    data-color={color}
    data-color-out={colorOut}
    class:list={["px-12 py-20 scroll-mt-4", className]}
>
    <div class="grid gap-4 md:grid-cols-2 py-12">
        <div
            data-pinned-title
            class:list={[
                "flex self-start gap-4 border-b border-alice-blue-400",
                isTitleOnLeft
                    ? "md:order-1 "
                    : "md:order-2  md:justify-self-end",
            ]}
            id={"data-"+id}
        >
            <slot name="title-icon" />
            <h2
                class="text-xl font-extralight uppercase text-alice-blue-400 font-mono md:text-3xl"
            >
                {title}
            </h2>
        </div>

        <div
            data-pinned-content
            class:list={isTitleOnLeft ? "md:order-2" : "md:order-1"}
        >
            <slot />
        </div>
    </div>
</section>

<script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.querySelectorAll<HTMLElement>("[data-pinned-section]").forEach(
        (section) => {
            const title = section.querySelector<HTMLElement>("[data-pinned-title]");
            const color = section.dataset.color;
            const colorOut = section.dataset.colorOut;

            if (!title) return;

            if (color) {
                gsap.to(section, {
                    backgroundColor: color,
                    scrollTrigger: {
                        trigger: section,
                        start: "top 90%",
                        end: "top top",
                        scrub: true,
                        invalidateOnRefresh: true,
                    },
                });
            }

            const media = gsap.matchMedia();

            media.add("(min-width: 768px)", () => {
                const trigger = ScrollTrigger.create({
                    trigger: title,
                    start: "top top+=90",
                    endTrigger: section,
                    end: "bottom bottom",
                    pin: true,
                    pinSpacing: false,
                });

                return () => trigger.kill();
            });
        },
    );
</script>
